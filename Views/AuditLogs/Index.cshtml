@model IEnumerable<DormitoryManagementSystem.Models.AuditLog>
@{
    ViewData["Title"] = "Audit Logs";
}

<h2>Audit Logs</h2>

<table class="table table-bordered table-sm">
    <thead class="table-dark">
        <tr><th>Timestamp</th><th>User</th><th>Action</th><th>Entity</th><th>Entity Id</th><th>Details</th></tr>
    </thead>
    <tbody>
        @foreach (var log in Model)
        {
            <tr>
                <td>@log.Timestamp.ToString("dd.MM.yyyy HH:mm:ss")</td>
                <td>@(log.User?.FullName ?? "System")</td>
                <td><span class="badge @(log.Action == "Create" ? "bg-success" : log.Action == "Delete" ? "bg-danger" : "bg-warning")">@log.Action</span></td>
                <td>@log.EntityName</td>
                <td>@log.EntityId</td>
                <td>@(log.Details ?? "-")</td>
            </tr>
        }
    </tbody>
</table>