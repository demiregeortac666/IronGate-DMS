@model DormitoryManagementSystem.Models.User
@{
    ViewData["Title"] = "Delete User";
}

<h2>Delete User</h2>
<div class="alert alert-danger"><strong>Warning!</strong> Delete user @Model.FullName (@Model.Username)?</div>

<table class="table" style="max-width:400px;">
    <tr><th>Username</th><td>@Model.Username</td></tr>
    <tr><th>Full Name</th><td>@Model.FullName</td></tr>
    <tr><th>Role</th><td>@(Model.Role?.RoleName ?? "-")</td></tr>
</table>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>