@model IEnumerable<DormitoryManagementSystem.Models.Document>
@{
    ViewData["Title"] = "Documents";
}

<h2>Document Management</h2>
<a asp-action="Upload" class="btn btn-primary mb-3">Upload Document</a>

<table class="table table-bordered">
    <thead class="table-dark">
        <tr><th>Student</th><th>File Name</th><th>Type</th><th>Uploaded</th><th>Actions</th></tr>
    </thead>
    <tbody>
        @foreach (var d in Model)
        {
            <tr>
                <td>@(d.Student?.FullName ?? "-")</td>
                <td>@d.FileName</td>
                <td><span class="badge bg-secondary">@d.FileType</span></td>
                <td>@d.UploadedAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td>
                    <a asp-action="Download" asp-route-id="@d.Id" class="btn btn-sm btn-info">Download</a>
                    <form asp-action="Delete" asp-route-id="@d.Id" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>