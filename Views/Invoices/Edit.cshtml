@model DormitoryManagementSystem.Models.Invoice

@{
    ViewData["Title"] = "Edit Invoice";
}

<h2>Edit Invoice #@Model.Id</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
}

@* POST to /Invoices/Edit/{id} with only the three editable fields.
   StudentId is immutable after creation and displayed as plain text.
   Status and PenaltyAmount are system-managed and not editable here. *@
<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Student</label>
        <input class="form-control" value="@Model.Student?.FullName" readonly disabled />
    </div>

    <div class="mb-3">
        <label class="form-label">Period (YYYY-MM)</label>
        <input type="text" name="periodMonth" class="form-control"
               value="@Model.PeriodMonth" placeholder="2026-04" maxlength="7" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Amount</label>
        <input type="number" name="amount" class="form-control"
               value="@Model.Amount" step="0.01" min="0.01" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Due Date</label>
        <input type="date" name="dueDate" class="form-control"
               value="@Model.DueDate.ToString("yyyy-MM-dd")" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Status</label>
        <input class="form-control" value="@Model.Status (system-managed)" readonly disabled />
        <small class="text-muted">Status is automatically derived from payments.</small>
    </div>

    <button type="submit" class="btn btn-success mt-2">Save Changes</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
