@model DormitoryManagementSystem.Models.InvoiceDetailsVM

@{
    ViewData["Title"] = "Invoice Details";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Invoice Details (#@Model.Invoice.Id)</h2>
        <a asp-action="Index" class="btn btn-secondary">← Back to Invoice List</a>
    </div>

    @* Top cards: invoice summary *@
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-primary">
                <div class="card-body text-center">
                    <h6 class="text-muted text-uppercase mb-2">Invoice Amount</h6>
                    <h3 class="mb-0">@Model.Invoice.Amount.ToString("C")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-success">
                <div class="card-body text-center">
                    <h6 class="text-muted text-uppercase mb-2">Total Paid</h6>
                    <h3 class="mb-0 text-success">@Model.TotalPaid.ToString("C")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm h-100 border-danger">
                <div class="card-body text-center">
                    <h6 class="text-muted text-uppercase mb-2">Remaining Balance</h6>
                    <h3 class="mb-0 text-danger fw-bold">@Model.RemainingAmount.ToString("C")</h3>
                </div>
            </div>
        </div>
    </div>

    @* Student and invoice information *@
    <div class="card shadow-sm mb-4">
        <div class="card-header fw-bold">Genel Bilgiler</div>
        <div class="card-body">
            <div class="row">
                <div class="col-sm-6">
                    <p><strong>Student:</strong> @(Model.Invoice.Student?.FullName ?? "Unknown")</p>
                    <p><strong>Room No.:</strong> @(Model.Invoice.Student?.Room?.RoomNumber ?? "Not Assigned")</p>
                </div>
                <div class="col-sm-6">
                    <p><strong>Period:</strong> @Model.Invoice.PeriodMonth</p>
                    <p><strong>Due Date:</strong> @Model.Invoice.DueDate.ToShortDateString()</p>
                    <p>
                        <strong>Status:</strong>
                        <span class="badge @(Model.Invoice.Status == "Paid" ? "bg-success" : "bg-warning")">
                            @Model.Invoice.Status
                        </span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    @* Payment history table *@
    <h4 class="mb-3">Payment History for This Invoice</h4>
    <div class="card shadow-sm">
        @if (Model.Payments.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Payment Date</th>
                            <th>Amount</th>
                            <th>Payment Method</th>
                            <th>Receipt No</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Model.Payments)
                        {
                            <tr>
                                <td>@payment.PaidAt.ToString("g")</td>
                                <td class="text-success fw-bold">@payment.Amount.ToString("C")</td>
                                <td>@(payment.Method ?? "-")</td>
                                <td>@(payment.ReceiptNo ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="card-body text-center text-muted">
                <p class="mb-0">There are no payment records for this invoice yet.</p>
            </div>
        }
    </div>
</div>