@{
    ViewData["Title"] = "Send Notification";
}

<h2 class="mb-4"><i class="bi bi-send"></i> Send Notification</h2>

<div class="card" style="max-width: 600px;">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <form asp-action="Send" method="post">
            <div class="mb-3">
                <label class="form-label">Recipient</label>
                <select name="userId" class="form-select" asp-items="ViewBag.UserId">
                    <option value="">-- Select User --</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Message</label>
                <textarea name="message" class="form-control" rows="4" required placeholder="Write your notification message..."></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-send"></i> Send</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>