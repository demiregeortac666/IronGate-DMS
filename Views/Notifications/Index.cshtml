@model IEnumerable<DormitoryManagementSystem.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-bell"></i> Notifications</h2>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Send" class="btn btn-primary"><i class="bi bi-send"></i> Send Notification</a>
    }
</div>

@if (!Model.Any())
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-bell-slash" style="font-size:3rem; color: var(--text-muted);"></i>
            <p class="mt-3" style="color: var(--text-muted);">No notifications yet.</p>
        </div>
    </div>
}
else
{
    <table class="table align-middle">
        <thead>
            <tr>
                <th>DATE</th>
                <th>MESSAGE</th>
                <th>STATUS</th>
                <th>ACTION</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var n in Model)
            {
                <tr style="@(!n.IsRead ? "border-left: 3px solid var(--accent-primary);" : "")">
                    <td>@n.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@n.Message</td>
                    <td>
                        @if (n.IsRead)
                        {
                            <span class="badge bg-success">Read</span>
                        }
                        else
                        {
                            <span class="badge bg-warning">Unread</span>
                        }
                    </td>
                    <td>
                        @if (!n.IsRead)
                        {
                            <form asp-action="MarkAsRead" asp-route-id="@n.Id" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i> Mark Read</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}