@model DormitoryManagementSystem.Models.Payment

@{
    ViewData["Title"] = "Edit Payment";
}

<h2>Edit Payment #@Model.Id</h2>

@if (!ViewData.ModelState.IsValid)
{
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
}

@* POST to /Payments/Edit/{id}. Only Amount, Method, and ReceiptNo are editable.
   InvoiceId and PaidAt are immutable after creation and shown as read-only. *@
<form asp-action="Edit" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label class="form-label">Invoice</label>
        <input class="form-control" value="Invoice #@Model.InvoiceId" readonly disabled />
        <small class="text-muted">Invoice cannot be changed after payment creation.</small>
    </div>

    <div class="mb-3">
        <label class="form-label">Paid At</label>
        <input class="form-control" value="@Model.PaidAt.ToString("dd.MM.yyyy HH:mm")" readonly disabled />
        <small class="text-muted">Payment date cannot be changed.</small>
    </div>

    <div class="mb-3">
        <label class="form-label">Amount</label>
        <input type="number" name="amount" class="form-control"
               value="@Model.Amount" step="0.01" min="0.01" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Method</label>
        <input type="text" name="method" class="form-control"
               value="@Model.Method" placeholder="Cash / Card / Transfer" maxlength="30" />
    </div>

    <div class="mb-3">
        <label class="form-label">Receipt No</label>
        <input type="text" name="receiptNo" class="form-control"
               value="@Model.ReceiptNo" maxlength="50" />
    </div>

    <button type="submit" class="btn btn-success mt-2">Save Changes</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
