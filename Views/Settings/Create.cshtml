@model DormitoryManagementSystem.Models.Setting
@{
    ViewData["Title"] = "Add Setting";
}

<h2 class="mb-4"><i class="bi bi-gear"></i> Add Setting</h2>

<div class="card" style="max-width: 600px;">
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label class="form-label">Key</label>
                <input asp-for="Key" class="form-control" placeholder="e.g. LatePenaltyRate" />
                <span asp-validation-for="Key" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Value</label>
                <input asp-for="Value" class="form-control" placeholder="e.g. 0.05" />
                <span asp-validation-for="Value" class="text-danger"></span>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>