@model IEnumerable<DormitoryManagementSystem.Models.Setting>

@{
    ViewData["Title"] = "Settings";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-gear-fill"></i> System Settings</h2>
        <div>
            @* NEW: Add setting button *@
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add Setting
            </a>

            @* NEW: Backup button *@
            <a asp-action="Backup" class="btn btn-secondary ms-2">
                <i class="bi bi-cloud-download"></i> Download Backup
            </a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 30%">Key</th>
                        <th style="width: 50%">Value</th>
                        <th style="width: 20%" class="text-end px-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td><code class="text-primary fw-bold">@s.Key</code></td>
                            <td>@s.Value</td>
                            <td class="text-end px-4">
                                @* EDIT *@
                                <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-sm btn-warning text-dark">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>

                                @* DELETE *@
                                <form asp-action="Delete" asp-route-id="@s.Id" method="post" style="display:inline;"
                                      onsubmit="return confirm('Deleting this setting may cause system issues. Are you sure?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3 text-muted">
        <small><i class="bi bi-info-circle"></i> Tip: Use the 'Download Backup' button regularly to keep your <b>dormitory.db</b> safe.</small>
    </div>
</div>