@model DormitoryManagementSystem.Models.StudentDetailsVM

@{
    ViewData["Title"] = "Student Details";
}

<h2>@Model.Student.FullName - Details</h2>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Personal Information</div>
            <div class="card-body">
                <p><strong>Student No.:</strong> @Model.Student.StudentNo</p>
                <p><strong>Telefon:</strong> @Model.Student.Phone</p>
                <p><strong>Room:</strong> @(Model.Student.Room != null ? Model.Student.Room.RoomNumber : "Not Assigned")</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Financial Summary</div>
            <div class="card-body">
                <p><strong>Total Invoiced:</strong> @Model.TotalInvoiced.ToString("C")</p>
                <p><strong>Total Paid:</strong> @Model.TotalPaid.ToString("C")</p>
                <h5 class="text-danger"><strong>Remaining Balance:</strong> @Model.RemainingDebt.ToString("C")</h5>
            </div>
        </div>
    </div>
</div>

<h4>Invoices</h4>
<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Period</th>
            <th>Due Date</th>
            <th>Amount</th>
            <th>Paid</th>
            <th>Remaining</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var inv in Model.Invoices)
        {
            var paidForInvoice = inv.Payments != null ? inv.Payments.Sum(p => p.Amount) : 0;
            var remForInvoice = (inv.Amount + inv.PenaltyAmount) - paidForInvoice;
            <tr>
                <td>@inv.PeriodMonth</td>
                <td>@inv.DueDate.ToShortDateString()</td>
                <td>@((inv.Amount + inv.PenaltyAmount).ToString("C"))</td>
                <td>@paidForInvoice.ToString("C")</td>
                <td>@remForInvoice.ToString("C")</td>
                <td>@inv.Status</td>
                <td>
                    <a asp-controller="Invoices" asp-action="Details" asp-route-id="@inv.Id" class="btn btn-sm btn-info">Invoice Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<div>
    <a asp-action="Index">Back to List</a>
</div>