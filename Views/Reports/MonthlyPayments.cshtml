@model List<DormitoryManagementSystem.Models.Reports.MonthlyPaymentsVM>

@{
    ViewData["Title"] = "Monthly Payments";
}

<h2>Monthly Payments</h2>

<table class="table table-bordered table-striped report-table">
    <thead class="table-dark">
        <tr>
            <th>Month</th>
            <th>Payment Count</th>
            <th>Total Amount</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MonthYear</td>
                <td>@item.PaymentCount</td>
                <td class="text-success fw-bold">@item.TotalAmount.ToString("C")</td>
            </tr>
        }
    </tbody>
</table>

<p class="mt-3 report-total"><strong>Grand Total:</strong> <span class="text-success">@Model.Sum(m => m.TotalAmount).ToString("C")</span></p>