@model DormitoryManagementSystem.Models.Setting
@{
    ViewData["Title"] = "Edit Setting";
}

<h2>Edit Setting</h2>
<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="form-group"><label>Key</label><input asp-for="Key" class="form-control" /></div>
    <div class="form-group mt-2"><label>Value</label><input asp-for="Value" class="form-control" /></div>
    <button type="submit" class="btn btn-success mt-3">Save</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Cancel</a>
</form>