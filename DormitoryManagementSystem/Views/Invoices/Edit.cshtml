@model DormitoryManagementSystem.Models.Invoice

<h2>Edit Invoice</h2>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Student</label>
        <select asp-for="StudentId" class="form-control" asp-items="ViewBag.StudentId"></select>
        <span asp-validation-for="StudentId" class="text-danger"></span>
    </div>

    <div class="form-group mt-2">
        <label>Period (YYYY-MM)</label>
        <input asp-for="PeriodMonth" class="form-control" />
        <span asp-validation-for="PeriodMonth" class="text-danger"></span>
    </div>

    <div class="form-group mt-2">
        <label>Amount</label>
        <input asp-for="Amount" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <div class="form-group mt-2">
        <label>Due Date</label>
        <input asp-for="DueDate" class="form-control" type="date" />
        <span asp-validation-for="DueDate" class="text-danger"></span>
    </div>

    <div class="form-group mt-2">
        <label>Status</label>
        <select asp-for="Status" class="form-control">
            <option>Unpaid</option>
            <option>Paid</option>
        </select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success mt-3">Save</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Back</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}