@model DormitoryManagementSystem.Models.Invoice

<h2>Delete Invoice</h2>

<p>Are you sure you want to delete this invoice?</p>

<ul>
    <li><b>Id:</b> @Model.Id</li>
    <li><b>Student:</b> @(Model.Student != null ? Model.Student.FullName : "-")</li>
    <li><b>Period:</b> @Model.PeriodMonth</li>
    <li><b>Amount:</b> @Model.Amount</li>
    <li><b>Status:</b> @Model.Status</li>
</ul>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>