@model IEnumerable<DormitoryManagementSystem.Models.MaintenanceRequest>

@{
    ViewData["Title"] = "Maintenance Requests";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-tools"></i> Maintenance Requests</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> New Request
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-octagon-fill"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Id</th>
                        <th>Room</th>
                        <th>Student</th>
                        <th>Description</th>
                        <th class="text-center">Status</th>
                        <th>Created At</th>
                        <th>Action Details</th>
                        <th class="text-end px-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        // Slightly emphasize row color based on status
                        string rowClass = item.Status switch
                        {
                            "Closed" => "table-light text-muted",
                            "Approved" => "table-info-subtle",
                            _ => ""
                        };

                        <tr class="@rowClass">
                            <td>@item.Id</td>
                            <td><strong>@item.Room?.RoomNumber</strong></td>
                            <td>@item.Student?.FullName</td>
                            <td>@item.Description</td>
                            <td class="text-center">
                                @* Updated badge section *@
                                @if (item.Status == "Open")
                                {
                                    <span class="badge bg-warning text-dark">Open</span>
                                }
                                else if (item.Status == "Approved")
                                {
                                    <span class="badge bg-info">Approved</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Closed</span>
                                }
                            </td>
                            <td><small>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small></td>
                            <td>
                                @if (item.Status == "Approved")
                                {
                                    <small class="text-info">Appr by: @item.ApprovedBy</small>
                                }
                                else if (item.Status == "Closed")
                                {
                                    <small class="text-success">Done: @item.ClosedAt?.ToString("dd.MM")</small>
                                }
                                else
                                {
                                    <small class="text-muted">Waiting...</small>
                                }
                            </td>
                            <td class="text-end px-4">
                                @* Role-based action buttons *@
                                @if ((User.IsInRole("Admin") || User.IsInRole("Staff")) && item.Status == "Open")
                                {
                                    <form asp-action="Approve" asp-route-id="@item.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-warning">Approve</button>
                                    </form>
                                }

                                @if ((User.IsInRole("Admin") || User.IsInRole("Staff")) && item.Status == "Approved")
                                {
                                    <form asp-action="Close" asp-route-id="@item.Id" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-success">Close</button>
                                    </form>
                                }

                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('Are you sure you want to delete this request?')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>