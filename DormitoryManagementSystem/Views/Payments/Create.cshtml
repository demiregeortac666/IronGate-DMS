@model DormitoryManagementSystem.Models.Payment

<h2>New Payment</h2>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label>Invoice</label>
        <select asp-for="InvoiceId" class="form-control" asp-items="ViewBag.InvoiceId">
            <option value="">-- Select Invoice --</option>
        </select>
        <span asp-validation-for="InvoiceId" class="text-danger"></span>
    </div>

    <div class="form-group mt-2">
        <label>Amount</label>
        <input asp-for="Amount" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>

    <div class="form-group mt-2">
        <label>Paid At</label>
        <input class="form-control" type="datetime-local" name="PaidAt"
               value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
    </div>

    <div class="form-group mt-2">
        <label>Method</label>
        <input asp-for="Method" class="form-control" placeholder="Cash / Card / Transfer" />
    </div>

    <div class="form-group mt-2">
        <label>Receipt No</label>
        <input asp-for="ReceiptNo" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success mt-3">Save</button>
    <a asp-action="Index" class="btn btn-secondary mt-3">Geri</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}